<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.animex.app.ui.home.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.animex.app.ui.search.SearchFragment"
        android:label="Cari">
        <argument
            android:name="query"
            android:defaultValue=""
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/genreFragment"
        android:name="com.animex.app.ui.genre.GenreFragment"
        android:label="Genre">
        <argument
            android:name="slug"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="name"
            android:defaultValue=""
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/scheduleFragment"
        android:name="com.animex.app.ui.schedule.ScheduleFragment"
        android:label="Jadwal" />

    <fragment
        android:id="@+id/animeDetailFragment"
        android:name="com.animex.app.ui.anime.AnimeDetailFragment"
        android:label="Detail">
        <argument
            android:name="slug"
            android:defaultValue=""
            app:argType="string" />
    </fragment>

</navigation>
