<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/syne_bold"
                android:text="ANIME"
                android:textColor="@color/cyan"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/syne_bold"
                android:text="X"
                android:textColor="@color/accent"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Search bar -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                app:boxBackgroundColor="@color/card"
                app:boxStrokeColor="@color/border"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/search_bar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/dm_sans"
                    android:hint="Cari anime..."
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Stats Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="14dp"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/stat_watches"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_bold"
                    android:text="—"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="orang nonton"
                    android:textColor="@color/muted"
                    android:textSize="10sp" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/border" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/stat_online"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_bold"
                    android:text="—"
                    android:textColor="@color/cyan"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="online"
                    android:textColor="@color/muted"
                    android:textSize="10sp" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/border" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/stat_watching"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_bold"
                    android:text="—"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="menonton"
                    android:textColor="@color/muted"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- History Section -->
        <LinearLayout
            android:id="@+id/hist_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/syne_bold"
                android:text="Riwayat Tonton"
                android:textColor="@color/text"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="10dp" />
        </LinearLayout>

        <!-- Ongoing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/syne_bold"
            android:text="▶ Sedang Tayang"
            android:textColor="@color/text"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/ongoing_shimmer"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginHorizontal="14dp"
            android:background="@color/card" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_ongoing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:visibility="gone" />

        <!-- Complete -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/syne_bold"
            android:text="✓ Selesai Tayang"
            android:textColor="@color/text"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/complete_shimmer"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginHorizontal="14dp"
            android:background="@color/card" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_complete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
